# =============================================================================
# Misinformation Detection System - Environment Variables
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  copy .env.example .env   (Windows)
#                       cp .env.example .env     (Linux/Mac)
#   2. Edit .env with your actual values
#   3. NEVER commit .env to git - it is in .gitignore
#
# Most variables have working defaults. You only need to change them
# if your setup differs from the standard configuration.
# =============================================================================

# --- Logging ---
# Controls how verbose the output is
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Ollama LLM Judge ---
# The system uses a LOCAL Ollama instance - no API key needed.
# Install Ollama from https://ollama.com
# Start with: ollama serve
# Pull model: ollama pull llama3
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# --- TensorFlow ---
# Suppresses verbose TensorFlow startup messages
# 0=all, 1=no INFO, 2=no WARNING, 3=no ERROR
TF_CPP_MIN_LOG_LEVEL=3

# --- Git Automation ---
# Whether the feedback loop automatically pushes commits to remote
# Set to true only if you have git credentials configured
GIT_AUTO_PUSH=false

# --- Data Paths ---
# Override the default data file locations from config.yaml
# Uncomment and set if your data is in a different location
# TRAIN_DATA_PATH=data/train.csv
# VAL_DATA_PATH=data/val.csv
# TEST_DATA_PATH=data/test.csv

# --- Feedback Store ---
# Path to the SQLite database for feedback loop persistence
# FEEDBACK_DB_PATH=feedback.db

# --- Reports ---
# Where evaluation reports and dashboard images are saved
# REPORTS_DIR=reports/
